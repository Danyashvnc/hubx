    "react-dom": "^18.3.1",
    "strophe.js": "^3.1.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "javascript-obfuscator": "^4.2.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
